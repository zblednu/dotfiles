// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "disable_ai": true,
  "audio": {
    "experimental.legacy_audio_compatible": false,
    "experimental.denoise": false,
    "experimental.auto_speaker_volume": false
  },
  "git": {
    "blame": {
      "show_avatar": false
    },
    "inline_blame": {
      "show_commit_summary": true
    }
  },
  "terminal": {
    "copy_on_select": true,
    "option_as_meta": true
  },
  "preview_tabs": {
    "enabled": false
  },
  "use_smartcase_search": false,
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  },
  "prettier": {
    "allowed": true
  },
  "colorize_brackets": true,
  "inlay_hints": {
    "enabled": true
  },
  "completions": {
    "words_min_length": 2
  },
  "indent_guides": {
    "background_coloring": "disabled",
    "coloring": "indent_aware",
    "active_line_width": 1,
    "line_width": 1
  },
  "soft_wrap": "none",
  "tab_size": 2,
  "vim": {
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true
  },
  "scrollbar": {
    "axes": {
      "vertical": true
    },
    "show": "auto"
  },
  "gutter": {
    "min_line_number_digits": 0
  },
  "relative_line_numbers": "disabled",
  "hover_popover_delay": 100,
  "scroll_beyond_last_line": "off",
  "diff_view_style": "unified",
  "which_key": {
    "enabled": false
  },
  "base_keymap": "VSCode",
  "vim_mode": true,
  "cursor_shape": "bar",
  "auto_update": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "session": {
    "trust_all_worktrees": true
  },
  "redact_private_values": true,
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": "One Thing Cool Dark",
}
